# ---------------------------------------------------------------------------
# LiveAvatar / HeyGen credentials
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored and must NEVER be committed.
# ---------------------------------------------------------------------------

# Server-side only. The LiveAvatar API key. Used solely in /app/api/* routes.
# Get it from https://app.liveavatar.com  ->  Developers page.
LIVEAVATAR_API_KEY=

# LiveAvatar API base URL. Not secret. Leave as-is unless HeyGen changes it.
LIVEAVATAR_API_URL=https://api.liveavatar.com

# The approved Brian Kaplan LiveAvatar ID.
BRIAN_AVATAR_ID=

# Brian's voice ID (from the LiveAvatar / HeyGen voice library).
BRIAN_VOICE_ID=

# The Context ID holding Brian's persona, guardrails and Q&A.
# This is configured on the LiveAvatar platform (the "Context" for the avatar).
BRIAN_CONTEXT_ID=

# Sandbox mode. "true" while building/rehearsing (no credits burned).
# Set to "false" for the real demo.
LIVEAVATAR_SANDBOX=true
